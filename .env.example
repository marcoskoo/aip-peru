# ─────────────────────────────────────────────────────────────────
# AIP PERÚ - Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to `.env` for local development, or set these
# variables in the Netlify dashboard (Site settings → Environment variables).

# Required: PostgreSQL connection string (Neon, Supabase, Railway, etc.)
# Must be a serverless-friendly Postgres provider with SSL support.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Required for NextAuth (only if you enable authentication features)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Disable Prisma logging in production
# PRISMA_LOG_LEVEL="error"
